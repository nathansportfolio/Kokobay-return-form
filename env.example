# Same variable name as web-score-app/apps/new and MoneyAdvert/moneyadvert-v2.
# Copy the value from web-score-app/apps/new/.env → MONGODB_URI
MONGODB_URI=

# Optional: MongoDB database name for Kokobay-only data (default: kokobay)
# MONGODB_DB=kokobay

# Optional: Shopify admin “View order in Shopify” on /returns/[order]
# Default store is koko-bay. If the order key in the URL is not the numeric id in
# admin, map it (JSON object):
# NEXT_PUBLIC_SHOPIFY_ORDER_ADMIN_ID_MAP={"2122":"12983974494594"}
# NEXT_PUBLIC_SHOPIFY_STORE_HANDLE=koko-bay

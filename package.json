{
  "name": "kokobay",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "dev:lan": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "list-active-products": "node --import tsx --env-file=.env.local ./scripts/list-active-shopify-products.ts",
    "missing-variant-skus": "node --import tsx --env-file=.env.local ./scripts/missing-variant-skus.ts",
    "list-product-colours": "node --import tsx --env-file=.env.local ./scripts/list-product-colours.ts",
    "list-product-titles-csv": "node --import tsx --env-file=.env.local ./scripts/list-product-titles-csv.ts",
    "shopify-stock-export": "node --import tsx --env-file=.env.local ./scripts/shopify-stock-export.ts",
    "shopify-handles-all-zero": "node --import tsx ./scripts/shopify-handles-all-zero-stock.ts",
    "active-export-all-zero-handles": "node --import tsx ./scripts/active-export-all-zero-handles.ts",
    "active2-stock-for-zero-handles": "node --import tsx ./scripts/active2-stock-for-zero-handles.ts",
    "active2-stock-for-zero-handles-csv": "node --import tsx ./scripts/active2-stock-for-zero-handles.ts -- --out active2-zero-handles-stock.csv",
    "list-inventory-for-handles": "node --import tsx ./scripts/list-inventory-for-handles.ts",
    "variant-stock": "node --import tsx ./scripts/variant-stock-for-handle.ts",
    "stock-restore-csv": "node --import tsx ./scripts/export-stock-restore-from-csvs.ts",
    "repopulate-stock-zero-fix": "pnpm shopify-stock-export -- --out shopify-stock-live.csv && pnpm stock-restore-csv -- --source shopify-stock-live.csv --active-csv active-products-2.csv --out stock-zero-fix.csv",
    "missing-stock": "node --import tsx --env-file=.env.local ./scripts/missing-stock.ts",
    "fix-zero-stock-from-export": "node --import tsx --env-file=.env.local ./scripts/fix-zero-stock-from-export.ts",
    "merge-products": "node scripts/merge-products.js",
    "export-shopify-csv": "node scripts/export-shopify-import-csv.js",
    "generate-shopify-metafields": "node scripts/generate-shopify-metafields.js",
    "active-products-shopify-headers": "node scripts/active-products-shopify-headers.js"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.0.0",
    "@phosphor-icons/react": "^2.1.10",
    "csv-parser": "^3.2.0",
    "fs": "0.0.1-security",
    "fs-extra": "^11.3.4",
    "jsbarcode": "^3.12.3",
    "json2csv": "6.0.0-alpha.2",
    "luxon": "^3.7.2",
    "mongodb": "^6.21.0",
    "next": "16.2.4",
    "nextjs-toploader": "^3.9.17",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jsbarcode": "^3.11.4",
    "@types/luxon": "^3.7.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "enhanced-resolve": "5.20.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}

# Shopify Admin API (server-only: /api/products, /api/orders, return form
# order lookup, warehouse /returns/{order}, customer-form verification)
# Copy to .env.local and fill in. Do not commit real secrets.
SHOPIFY_STORE=koko-bay.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Product JSON APIs (`GET /api/products`, `GET /api/products/{id}`) — same value in both vars.
# Generate e.g. `openssl rand -hex 24`. Required for routes + warehouse UI fetch.
KOKOBAY_PRODUCTS_API_KEY=kb_prod_replace_with_random_hex
NEXT_PUBLIC_KOKOBAY_PRODUCTS_API_KEY=kb_prod_replace_with_random_hex

# Public: order admin links use https://admin.shopify.com/store/{handle}/orders/{id}/refund
NEXT_PUBLIC_SHOPIFY_STORE_HANDLE=koko-bay

# Optional: PIN gate (cookie `site_access` = user | admin). If both are unset, login is not enforced.
# Values are in the client bundle; treat as a light gate, not a secret.
NEXT_PUBLIC_SITE_PIN_USER=
NEXT_PUBLIC_SITE_PIN_ADMIN=
# Map display order # / ref -> numeric order id in admin (JSON object string)
# NEXT_PUBLIC_SHOPIFY_ORDER_ADMIN_ID_MAP={"333344":"12985108038018"}
